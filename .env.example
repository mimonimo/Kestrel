# ========= Frontend =========
# 브라우저에서 API를 호출할 때 쓰이는 주소 (localhost)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Next.js 서버 컴포넌트가 컨테이너 네트워크 내부에서 호출할 때 쓰는 주소
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

# ========= Backend =========
DATABASE_URL=postgresql+asyncpg://cvewatch:cvewatch@postgres:5432/cvewatch
REDIS_URL=redis://redis:6379/0
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-in-production

# External API keys (Step 3에서 사용)
NVD_API_KEY=
GITHUB_TOKEN=

# ========= Infra =========
POSTGRES_USER=cvewatch
POSTGRES_PASSWORD=cvewatch
POSTGRES_DB=cvewatch

# ========= Observability (선택) =========
# 비워 두면 코드에서 init 자체를 건너뜁니다. 활성화하려면
#   pip install -e ".[sentry]"  /  ".[otel]"
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=cve-watch-backend
