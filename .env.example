# ========= Compose =========
COMPOSE_PROJECT_NAME=kestrel

# ========= Frontend =========
# 브라우저에서 API를 호출할 때 쓰이는 주소 (localhost)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Next.js 서버 컴포넌트가 컨테이너 네트워크 내부에서 호출할 때 쓰는 주소
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

# ========= Backend =========
DATABASE_URL=postgresql+asyncpg://kestrel:kestrel@postgres:5432/kestrel
REDIS_URL=redis://redis:6379/0
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-in-production

# External API keys (Step 3에서 사용)
NVD_API_KEY=
GITHUB_TOKEN=

# ========= Infra =========
POSTGRES_USER=kestrel
POSTGRES_PASSWORD=kestrel
POSTGRES_DB=kestrel

# ========= AI 분석 — Claude Code CLI 연동 (선택) =========
# 별도 Anthropic API 키 없이 본인 Claude Code 구독으로 CVE 분석을 돌리고 싶다면
# 1로 설정하고 docker-compose.claude-cli.yml 를 함께 사용하세요.
#   docker compose -f docker-compose.yml -f docker-compose.claude-cli.yml up -d --build
# 바인드 마운트 경로를 기본값(~/.claude)에서 바꾸려면 CLAUDE_HOME/CLAUDE_CONFIG 를 지정.
INSTALL_CLAUDE_CLI=0
# CLAUDE_HOME=/Users/you/.claude
# CLAUDE_CONFIG=/Users/you/.claude.json

# ========= Observability (선택) =========
# 비워 두면 코드에서 init 자체를 건너뜁니다. 활성화하려면
#   pip install -e ".[sentry]"  /  ".[otel]"
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=kestrel-backend
