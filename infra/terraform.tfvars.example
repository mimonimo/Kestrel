# 이 파일을 terraform.tfvars 로 복사한 뒤 값을 채우세요.
# terraform.tfvars 는 .gitignore 에 등록돼 커밋되지 않습니다.

env             = "prod"
aws_region      = "ap-northeast-2"

# 도메인이 아직 없으면 비워두세요 — CloudFront 기본 URL 로 동작합니다.
# domain_name     = "kestrel.example.com"
# route53_zone_id = "Z0123456789ABCDEFGHIJ"

# 이미지 태그 — CI 가 ECR 푸시 후 갱신. 첫 apply 전에 ECR 이 비어 있으면
# 아래 세 값을 모두 "latest" 로 두고 부트스트랩 가이드의 "ECR 푸시" 단계
# (terraform apply 후) 를 진행하세요.
image_tag_api       = "latest"
image_tag_frontend  = "latest"
image_tag_scheduler = "latest"

# ──────────────────────────────────────────────────────────────────────
# 첫 apply 후 AWS 콘솔 또는 CLI 로 채워야 할 Secrets Manager 값
# (`${prefix}/app/runtime` 의 각 키 — JSON object 의 entry)
#   NVD_API_KEY            — NVD API 키 (선택, 비우면 동기화 속도만 느려짐)
#   GITHUB_TOKEN           — GitHub PAT (선택, GHSA 동기화용)
#   ANTHROPIC_API_KEY      — Claude API 키 fallback (보통 비워두고 OAuth 사용)
#   SENTRY_DSN             — Sentry DSN (선택)
#   INITIAL_ADMIN_EMAILS   — 가입 시 자동 admin 되는 이메일 콤마 리스트
# JWT_SECRET / MEILI_MASTER_KEY 는 random_password 로 자동 생성되어 같이 저장됩니다.
# ──────────────────────────────────────────────────────────────────────
